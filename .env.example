# Copy this file to .env and fill in your values
# cp .env.example .env

# Google Gemini API key (required)
# Get one at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ElevenLabs API key (required for real TTS, optional with MOCK_TTS=true)
# Get one at: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# ElevenLabs voice ID (optional, default is "Rachel")
# Browse voices at: https://elevenlabs.io/app/voice-library
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Set to true to skip ElevenLabs API calls during development
MOCK_TTS=true
